{
  "hooks": {
    "SessionStart": [
      {
        "matcher": ".*",
        "hooks": [{
          "type": "command",
          "command": "wtcli forward-hook -c gemini -e agent.session.start"
        }]
      }
    ],
    "SessionEnd": [
      {
        "matcher": ".*",
        "hooks": [{
          "type": "command",
          "command": "wtcli forward-hook -c gemini -e agent.session.end"
        }]
      }
    ],
    "BeforeAgent": [
      {
        "matcher": ".*",
        "hooks": [{
          "type": "command",
          "command": "wtcli forward-hook -c gemini -e agent.prompt.submit"
        }]
      }
    ],
    "BeforeTool": [
      {
        "matcher": ".*",
        "hooks": [{
          "type": "command",
          "command": "wtcli forward-hook -c gemini -e agent.tool.starting"
        }]
      }
    ],
    "AfterTool": [
      {
        "matcher": ".*",
        "hooks": [{
          "type": "command",
          "command": "wtcli forward-hook -c gemini -e agent.tool.finished"
        }]
      }
    ],
    "Notification": [
      {
        "matcher": ".*",
        "hooks": [{
          "type": "command",
          "command": "wtcli forward-hook -c gemini -e agent.notification"
        }]
      }
    ],
    "AfterAgent": [
      {
        "matcher": ".*",
        "hooks": [{
          "type": "command",
          "command": "wtcli forward-hook -c gemini -e agent.stop"
        }]
      }
    ]
  }
}
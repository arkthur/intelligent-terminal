{
  "hooks": {
    "SessionStart": [
      {
        "matcher": ".*",
        "hooks": [{
          "type": "command",
          "command": "wtcli forward-hook -c claude -e agent.session.start"
        }]
      }
    ],
    "SessionEnd": [
      {
        "matcher": ".*",
        "hooks": [{
          "type": "command",
          "command": "wtcli forward-hook -c claude -e agent.session.end"
        }]
      }
    ],
    "Notification": [
      {
        "matcher": ".*",
        "hooks": [{
          "type": "command",
          "command": "wtcli forward-hook -c claude -e agent.notification"
        }]
      }
    ],
    "UserPromptSubmit": [
      {
        "matcher": ".*",
        "hooks": [{
          "type": "command",
          "command": "wtcli forward-hook -c claude -e agent.prompt.submit"
        }]
      }
    ],
    "PreToolUse": [
      {
        "matcher": ".*",
        "hooks": [{
          "type": "command",
          "command": "wtcli forward-hook -c claude -e agent.tool.starting"
        }]
      }
    ],
    "PostToolUse": [
      {
        "matcher": ".*",
        "hooks": [{
          "type": "command",
          "command": "wtcli forward-hook -c claude -e agent.tool.finished"
        }]
      }
    ],
    "PostToolUseFailure": [
      {
        "matcher": ".*",
        "hooks": [{
          "type": "command",
          "command": "wtcli forward-hook -c claude -e agent.tool.failed"
        }]
      }
    ],
    "StopFailure": [
      {
        "matcher": ".*",
        "hooks": [{
          "type": "command",
          "command": "wtcli forward-hook -c claude -e agent.error"
        }]
      }
    ],
    "Stop": [
      {
        "matcher": ".*",
        "hooks": [{
          "type": "command",
          "command": "wtcli forward-hook -c claude -e agent.stop"
        }]
      }
    ],
    "SubagentStop": [
      {
        "matcher": ".*",
        "hooks": [{
          "type": "command",
          "command": "wtcli forward-hook -c claude -e agent.subagent.stop"
        }]
      }
    ]
  }
}